#!/bin/sh -e
##:
#h: Usage: ssh-h-ping SSH,...
#h:
#h: Login in remote machines and print `uname -s`.
#h:
#h: Environment variables: SSH, SSH_H_LIST
##:
ssh_h_ping() {
    local m
    for m in $(${SSH_H_LIST:-echo} "$@" | tr ',' ' '); do
        printf '%-10s : ' "${m}"
        if ! ${SSH} "${m}" "uname -a | sed 's| *\\#.*||'" 2>/dev/null; then
            echo "ERROR"
        fi
    done
}
## -------------------------------------------------------------------
: ${SSH:=ssh -o PasswordAuthentication=no -o BatchMode=yes -o ConnectTimeout=2}
if test @"${0##*/}" = @"ssh-h-ping"; then
    case "${1}" in
        ''|-h|--help) sed -n 's/^ *#h: \{0,1\}//p' "$0" ;;
        *)            ssh_h_ping "$@"; exit 0;;
    esac
fi


