#!/bin/sh -e
##:
#h: Usage: ssh-h-history {-V , [-d] SSH,... }
#h:
#h: Print the last commands executed on the specified machines.
#h:
#h: With "-d" the history is appended to "~/.ssh-h-history/SSH" and
#h: then removed in the remote.
#h:
#h: Environment variables: SSH_H_LIST, SSH_H_HISTORY_DIRECTORY
##:
ssh_h_history() {
    local OPTIND optopt ssh opt_d= tmp="${HOME}/.ssh-h-history.tmp"

    ## Parse command line arguments.
    while getopts "d" optopt; do
        case $optopt in
            d)  opt_d=y;;
            \?) return 1;;
        esac
    done
    shift $(( $OPTIND - 1 ))
    
    ## For each specified machine.
    for ssh in $(${SSH_H_LIST:-echo} "$@" | tr ',' ' '); do
        echo "== ${ssh}"
        ${SSH} "${ssh}" '
            for f in ~/.history ~/.ash_history ~/.bash_history; do
                if test -f "$f"; then
                    cat "$f"
                fi
            done' > "${tmp}"
        if test -n "${opt_d}"; then
            mkdir -p "${SSH_H_HISTORY_DIRECTORY}"
            cat "${tmp}" >> "${SSH_H_HISTORY_DIRECTORY}/${ssh}"
            ssh -T "${ssh}" '
                rm -f ~/.history ~/.ash_history ~/.bash_history
            '
        else
            tail -n 10 "${tmp}"
        fi
        
    done

    ## Cleanup.
    rm -f "${tmp}"
}
## -------------------------------------------------------------------
: ${SSH:=ssh -o PasswordAuthentication=no -o BatchMode=yes -o ConnectTimeout=2}
: ${SSH_H_HISTORY_DIRECTORY:=${HOME}/.ssh-h-history}
if test @"${0##*/}" = @"ssh-h-history"; then
    case "${1}" in
        ''|-h|--help) sed -n 's/^ *#h: \{0,1\}//p' "$0";;
        -*V*)         echo "SSH_H_HISTORY_DIRECTORY : ${SSH_H_HISTORY_DIRECTORY}";;
        *)            ssh_h_history "$@";;
    esac
    exit 0
fi
