#!/bin/sh -e
##:
#h: Usage: ssh-h-list l|HOST,...
#h:
#h: Execute $SSH_H_LIST to list machines the same way "ssh-h-*" programs do.
#h:
#h: Write a shell script in "$SSH_H_LIST", ehe script takes a group name
#h: and prints the machine names. When "l" the script should list the groups.
#h:
#h: Use ${SSH:-ssh -o PasswordAuthentication=no -o BatchMode=yes -o ConnectTimeout=2}
##:
##: :SKIP:
##:
ssh_h_list() {
    printf '%-30s  %-30s  %-30s\n' $(${SSH_H_LIST:-echo} "$@" | tr ',' ' ')
}
## -------------------------------------------------------------------
if test @"${0##*/}" = @"ssh-h-list"; then
    case "${1}" in
        -h|--help) sed -n 's/^ *#h: \{0,1\}//p' "$0" ;;
        *)         ssh_h_list "$@"; exit 0           ;;
    esac
fi
