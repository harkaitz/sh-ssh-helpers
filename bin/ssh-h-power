#!/bin/sh -e
##:
#h: Usage: ssh-h-power SSH,... [off|restart]
#h:
#h: Print the uptime, power off or restart remote machines.
#h:
#h: Supported remotes: Linux/OpenBSD/Windows(Busybox/Cygwin/Msys).
#h: Environment variables: SSH_H_LIST
##:
ssh_h_power() {
    local m
    for m in $(${SSH_H_LIST:-echo} "$@" | tr ',' ' '); do
        case "$2" in
            '')      printf '%-10s : ' "${m}"; ssh_h_power_status  "$m";;
            off)     printf '%-10s : ' "${m}"; ssh_h_power_off     "$m";;
            restart) printf '%-10s : ' "${m}"; ssh_h_power_restart "$m";;
            *)       echo >&2 "error: Invalid argument: ${m}"; return 1;;
        esac
    done
}
## -------------------------------------------------------------------
ssh_h_power_status() {
    ${SSH} "$1" "uptime" || true
}
ssh_h_power_off() {
    ${SSH} "$1" '
    case "$(uname -s)" in
        Linux)      shutdown -h now    ;;
        OpenBSD)    shutdown -p now    ;;
        Windows_NT) cmd /C shutdown /p ;;
        MSYS_*)     cmd /C shutdown /p ;;
        CYGWIN_*)   cmd /C shutdown /p ;;
        *)          echo >&2 "error: Unsupported platform: $(uname -s)."; exit 1;;
    esac
    ' || true
}
ssh_h_power_restart() {
    ${SSH} "$1" '
    case "$(uname -s)" in
        Linux)      shutdown -h now    ;;
        OpenBSD)    shutdown -p now    ;;
        Windows_NT) cmd /C shutdown /p ;;
        MSYS_*)     cmd /C shutdown /p ;;
        CYGWIN_*)   cmd /C shutdown /p ;;
        *)          echo >&2 "error: Unsupported platform: $(uname -s)."; exit 1;;
    esac
    ' || true
}

## -------------------------------------------------------------------
: ${SSH:=ssh -o PasswordAuthentication=no -o BatchMode=yes -o ConnectTimeout=2}
if test @"${0##*/}" = @"ssh-h-power"; then
    case "${1}" in
        ''|-h|--help) sed -n 's/^ *#h: \{0,1\}//p' "$0";;
        *)            ssh_h_power "$@"; exit 0;;
    esac
fi
