#!/bin/sh -e
##:
#h: Usage: ssh-h-speed SSH,...
#h:
#h: Tell the upload and download speed over SSH (requires GNU dd).
#h:
#h: Environment variables: SSH, SSH_H_LIST
##:
ssh_h_speed() {
    local mb=40 srv cmd1 cmd2
    cmd1="dd if=/dev/zero count=$((2*${mb}*1000)) status=none"
    cmd2="dd of=/dev/null status=none"
    for srv in $(${SSH_H_LIST:-echo} "$@" | tr ',' ' '); do
        echo "== ${srv}"
        echo "[Upload (${mb} MB)]"
        sh -c "${cmd1}" | ${SSH} "${srv}" "${cmd2}"
        echo "[Download (${mb} MB)]"
        ${SSH} "${srv}" "${cmd1}" | sh -c "${cmd2}"
    done
}
## -------------------------------------------------------------------
: ${SSH:=ssh -o PasswordAuthentication=no -o BatchMode=yes -o ConnectTimeout=2}
if test @"${0##*/}" = @"ssh-h-speed"; then
    case "${1}" in
        ''|-h|--help) sed -n 's/^ *#h: \{0,1\}//p' "$0";;
        *)            ssh_h_speed "$@"; exit 0;;
    esac
fi
