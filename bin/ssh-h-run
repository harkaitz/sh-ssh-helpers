#!/bin/sh -e
##:
#h: Usage: ssh-h-run SSH,... COMMAND
#h:
#h: Execute the same command in multiple machines.
#h:
#h: Environment variables: SSH_H_LIST
##:
ssh_h_run() {
    local ssh="$(${SSH_H_LIST:-echo} "$1" | tr ',' ' ')"
    shift
    for ssh in ${ssh}; do
        echo "== ${ssh}"
        if ${SSH} "${ssh}" "$*"; then
            true
        fi
    done
}
## -------------------------------------------------------------------
: ${SSH:=ssh -o PasswordAuthentication=no -o BatchMode=yes -o ConnectTimeout=2}
if test @"${SCRNAME:-$(basename "$0")}" = @"ssh-h-run"; then
    case "${1}" in
        ''|-h|--help) sed -n 's/^ *#h: \{0,1\}//p' "$0";;
        *)            ssh_h_run "$@"; exit 0;;
    esac
fi
